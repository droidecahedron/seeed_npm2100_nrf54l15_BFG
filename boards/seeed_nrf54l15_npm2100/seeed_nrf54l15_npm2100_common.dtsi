#include "seeed_nrf54l15_npm2100_nrf54l_05_10_15-pinctrl.dtsi"

/ {
	leds {
		compatible = "gpio-leds";

		led0: led_0 {
			gpios = <&gpio2 6 (GPIO_ACTIVE_LOW | GPIO_PULL_UP)>;
			label = "Red surface-mount LED";
		};

		led1: led_1 {
			gpios = <&gpio1 9 (GPIO_ACTIVE_LOW | GPIO_PULL_UP | NRF_DRIVE_E0E1)>;
			label = "Red external LED";
		};
	};

	pwmleds {
		compatible = "pwm-leds";

		pwm_led1: pwm_led_1 {
			pwms = <&pwm20 0 PWM_MSEC(20) PWM_POLARITY_INVERTED>;
		};
	};

	buttons {
		compatible = "gpio-keys";

		button0: button_0 {
			gpios = <&gpio0 0 (GPIO_PULL_UP | GPIO_ACTIVE_LOW)>;
			label = "Push button KEY";
			zephyr,code = <INPUT_KEY_0>;
		};
	};

	aliases {
		led0 = &led0;
		pwm-led0 = &pwm_led1;
		sw0 = &button0;
		watchdog0 = &wdt31;
	};
};

&pwm20 {
	status = "okay";
	pinctrl-0 = <&pwm20_default>;
	pinctrl-1 = <&pwm20_sleep>;
	pinctrl-names = "default", "sleep";
};

&i2c30 {
	status = "okay";
	pinctrl-0 = <&i2c30_default>;
	pinctrl-1 = <&i2c30_sleep>;
	pinctrl-names = "default", "sleep";

	npm2100_pmic: pmic@74 {
		compatible = "nordic,npm2100";
		reg = <0x74>;

		npm2100_gpio: gpio-controller {
			compatible = "nordic,npm2100-gpio";
			gpio-controller;
			#gpio-cells = <2>;
			ngpios = <2>;
		};

		npm2100_regulators: regulators {
			compatible = "nordic,npm2100-regulator";

			npm2100_boost: BOOST {
				regulator-min-microvolt = <1800000>;
				regulator-max-microvolt = <3300000>;
				/* boost is always on by design */
				regulator-always-on;
			};

			npm2100_ldosw: LDOSW {
				regulator-min-microvolt = <800000>;
				regulator-max-microvolt = <3000000>;
			};
		};

		npm2100_wdt: watchdog {
			compatible = "nordic,npm2100-wdt";
		};

		npm2100_vbat: vbat {
			compatible = "nordic,npm2100-vbat";
		};
	};
};

/* DISABLED NODES */

&uart20 {
	status = "disabled";
	current-speed = <115200>;
	pinctrl-0 = <&uart20_default>;
	pinctrl-1 = <&uart20_sleep>;
	pinctrl-names = "default", "sleep";
};

&uart30 {
	status = "disabled";
	current-speed = <115200>;
	pinctrl-0 = <&uart30_default>;
	pinctrl-1 = <&uart30_sleep>;
	pinctrl-names = "default", "sleep";
};

&hfxo {
	status = "disabled";
	startup-time-us = <854>;
};
